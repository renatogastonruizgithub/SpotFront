# ApiRestSpot (ASP.NET Web API). Sin barra final; las rutas se arman en `src/lib/apiUrl.js`.
VITE_API_BASE_URL=http://localhost:54512

# Rol para registro: solo query string en el API, no va en el body con email/contraseña.
VITE_REGISTRO_ID_ROL=1

# Ruta POST de registro (sin barra inicial opcional). Por defecto: /api/usuarios (Web API clásico).
# Si en el backend tenés [Route("registrarUsuarios")] en la acción, probá:
# VITE_API_REGISTRO_PATH=/api/usuarios/registrarUsuarios
VITE_API_REGISTRO_PATH=/api/usuarios

# Si preferís pasar todo por el proxy de Vite (misma origin), podés usar:
# VITE_API_BASE_URL=
# y en su lugar confiar en las rutas relativas /api/... y /Auth/... (ver vite.config.js).
# En ese caso las peticiones van a :5173 y el proxy reenvía a :54512.

# Opcional: descomentá las dos líneas para fingir que estás en esas coords (prueba del bar en Córdoba). Reiniciá npm run dev.
VITE_DEV_LAT=-31.44953820873942
VITE_DEV_LNG=-64.23541405366213

# Radio en km de la primera búsqueda (subilo si tus bares están lejos del punto de prueba). Reiniciá npm run dev.
VITE_MAPA_RADIO_KM=30
