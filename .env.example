# Copiá a `.env` y ajustá el host/puerto del API (IIS Express / ApiRestSpot).
VITE_API_BASE_URL=http://localhost:54512

# Rol de fallback (si no hay estado de navegación): 2 = cliente
VITE_REGISTRO_ID_ROL=2

# Fallbacks de onboarding (si falla GET /api/roles/public)
VITE_REGISTRO_ID_ROL_CLIENTE=2
VITE_REGISTRO_ID_ROL_PROPIETARIO=3

# Opcional — coords y radio del mapa en desarrollo
# VITE_DEV_LAT=
# VITE_DEV_LNG=
# VITE_MAPA_RADIO_KM=10
