# Copiá a `.env` y ajustá el host/puerto del API (IIS Express / ApiRestSpot).
VITE_API_BASE_URL=http://localhost:54512

# id_rol solo en query al registrar (no forma parte del JSON email/contraseña)
VITE_REGISTRO_ID_ROL=1

# POST registro: suele ser /api/usuarios; si tu acción tiene otra ruta, ajustá aquí
# VITE_API_REGISTRO_PATH=/api/usuarios

# Opcional — coords y radio del mapa en desarrollo
# VITE_DEV_LAT=
# VITE_DEV_LNG=
# VITE_MAPA_RADIO_KM=10
